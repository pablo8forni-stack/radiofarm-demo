{
  "name": "radiofarm-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dev:staging": "vite --mode staging",
    "build:staging": "vite build --mode staging",
    "lint": "oxlint",
    "preview": "vite preview",
    "seed": "node scripts/seed.mjs",
    "test:staging": "node --env-file=.env.staging --test --test-concurrency=1 --test-timeout=30000 scripts/testing/reglas.test.mjs scripts/testing/transacciones.test.mjs scripts/testing/anulacion.test.mjs scripts/testing/solicitudes.test.mjs",
    "test:emulator": "firebase emulators:exec --only firestore,auth --project radiofarm-fuesmen-staging \"node --env-file=.env.emulator --test --test-concurrency=1 --test-timeout=30000 scripts/testing/reglas.test.mjs scripts/testing/transacciones.test.mjs scripts/testing/anulacion.test.mjs scripts/testing/solicitudes.test.mjs\"",
    "staging:reset": "firebase firestore:delete --all-collections --project radiofarm-fuesmen-staging --force"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "html5-qrcode": "^2.3.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "firebase-admin": "^14.1.0",
    "firebase-tools": "^15.22.4",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0"
  }
}
